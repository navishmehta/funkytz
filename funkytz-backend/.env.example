# --- Server ---
PORT=5000
NODE_ENV=production

# Comma-separated list of allowed frontend origins (storefront + admin panel)
CLIENT_ORIGINS=http://localhost:5173,http://localhost:5174

# --- MongoDB Atlas ---
# Get this from https://cloud.mongodb.com -> Database -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/funkytz?retryWrites=true&w=majority

# --- JWT Auth (admin panel login) ---
# Generate a long random string, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Seed / bootstrap admin account (used only by `npm run seed:admin`) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
ADMIN_EMAIL=admin@funkytz.com

# --- Cloudinary (product image storage) ---
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
